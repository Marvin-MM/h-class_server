{
  "name": "h-class-lms-server",
  "version": "1.0.0",
  "description": "Production-grade LMS backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:workers": "tsx watch src/workers.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "lms",
    "learning-management-system"
  ],
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1005.0",
    "@aws-sdk/s3-request-presigner": "^3.1005.0",
    "@prisma/client": "^7.4.2",
    "@stream-io/node-sdk": "^0.7.44",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "envalid": "^8.1.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ical-generator": "^10.0.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "nanoid": "^3.3.11",
    "nodemailer": "^8.0.2",
    "rate-limit-redis": "^4.3.1",
    "stream-chat": "^9.35.1",
    "stripe": "^20.4.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
